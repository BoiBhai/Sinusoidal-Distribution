n = length(data)
kernel = function(x) {
# sapply handles the non-vectorized parameter 'a' in dsinu
sum(sapply(data - h, function(a_val) dsinu(x, a_val, 2 * h, s, k))) / (n * h)
}
return(Vectorize(kernel))
}
