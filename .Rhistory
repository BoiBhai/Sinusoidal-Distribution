sidebarLayout(
sidebarPanel(
sliderInput("h", "Bandwidth (h):", min = 0, max = 10, value = 0.2, step = 0.1),
sliderInput("s", "Warp (s):", min = 0, max = 10, value = 1, step = 0.1),
sliderInput("k", "Concentration (k):", min = 0, max = 10, value = 1, step = 0.1)
),
mainPanel(
plotOutput("kdePlot")
)
)
)
server <- function(input, output) {
# Implementation of dsinu
dsinu <- function(x, a, d, s, k) {
z <- (x - a) / d
# Numerical normalization constant calculation
C_inv <- integrate(function(t) sin(pi * t^s)^k, 0, 1)$value
res <- ifelse(z >= 0 & z <= 1, (1 / (d * C_inv)) * sin(pi * z^s)^k, 0)
return(res)
}
# User's provided kernel logic
sinu.kernel = function(data, h, s, k){
n = length(data)
kernel = function(x){
sum1 = 0
for(xi in data){
sum1 = dsinu(x, xi-h, 2*h, s, k) + sum1
}
1/(n*h) * sum1
}
return(kernel)
}
data1 <- rnorm(1000)
output$kdePlot <- renderPlot({
kde1 <- sinu.kernel(data1, h = input$h, s = input$s, k = input$k)
curve(kde1, xlim = c(-3, 3), main = "KDE Plot", ylab = "Density", xlab = "x")
})
}
shinyApp(ui = ui, server = server)
