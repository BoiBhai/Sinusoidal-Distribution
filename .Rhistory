library(shiny)
library(Rcpp)
cppFunction('
NumericVector dsinu_cpp(double x, NumericVector a, double d, double s, double k, double C_inv) {
int n = a.size();
NumericVector res(n);
for(int i = 0; i < n; i++) {
double z = (x - a[i]) / d;
if (z >= 0 && z <= 1) {
res[i] = (1.0 / (d * C_inv)) * pow(sin(M_PI * pow(z, s)), k);
} else {
res[i] = 0;
}
}
return res;
}')
ui <- fillPage(
padding = 10,
sidebarLayout(
sidebarPanel(
sliderInput("h", "h", 0.01, 10, 0.2, 0.1),
sliderInput("s", "s", 0.01, 10, 1, 0.1),
sliderInput("k", "k", 0.01, 10, 1, 0.1)
),
mainPanel(plotOutput("p"))
)
)
server <- function(input, output) {
data1 <- rnorm(1000)
output$p <- renderPlot({
h <- input$h
s <- input$s
k <- input$k
a_vals <- data1 - h
d_val <- 2 * h
C_inv <- integrate(function(t) sin(pi * t^s)^k, 0, 1)$value
kde_func <- function(x) {
sum(dsinu_cpp(x, a_vals, d_val, s, k, C_inv)) / length(data1)
}
plot(density(data1))
curve(Vectorize(kde_func)(x), add = TRUE, col = "red", lwd = 2)
})
}
shinyApp(ui, server)
