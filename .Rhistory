curve.fg = function(f, g, xlim=c(-1,1), label_dists=list(Hel_dist, KL_dist)) {
curve(g, xlim=xlim, ylab='Density')
curve(f, add=T, col='red')
vals <- vapply(
names(label_dists),
function(nm) {
val <- label_dists[[nm]](f, g)
paste0(nm, ": ", signif(val, 6))
},
character(1)
)
legend('topright', legend=c(substitute(f), substitute(g)), fill=c('red', 'black'), lwd=1)
invisible(vals)
}
