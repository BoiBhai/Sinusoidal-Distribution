helpText("Adjust parameters to see how the 'Sum of Bumps' changes."),
sliderInput("h", "Bandwidth (h):", min = 0.01, max = 2, value = 0.3, step = 0.05),
sliderInput("s", "Warp/Skew (s):", min = 0.1, max = 5, value = 1.0, step = 0.1),
sliderInput("k", "Concentration (k):", min = 0.1, max = 10, value = 1.0, step = 0.5),
hr(),
actionButton("resample", "Generate New Data (n=200)")
),
mainPanel(
plotOutput("kdePlot", height = "600px"),
wellPanel(
p("The red curve is the sum of sinusoidal bumps centered at each data point."),
p("The individual bumps (scaled down) are shown in grey to visualize the composition.")
)
)
)
)
# 3. Shiny Server
server <- function(input, output) {
# Reactive data generation
vals <- reactiveValues(data = rnorm(200))
observeEvent(input$resample, {
vals$data <- rnorm(200)
})
output$kdePlot <- renderPlot({
data <- vals$data
n <- length(data)
h <- input$h
s <- input$s
k <- input$k
# Define grid for plotting
x_grid <- seq(min(data) - 2, max(data) + 2, length.out = 400)
# Calculate the KDE: Average of dsinu(x, xi-h, 2*h, s, k)
# This is vector-efficient
kde_y <- sapply(x_grid, function(x) {
mean(dsinu(x, data - h, 2*h, s, k))
})
# Plotting
plot(x_grid, kde_y, type = "l", lwd = 3, col = "firebrick",
ylim = c(0, max(kde_y) * 1.1),
main = paste("Sinusoidal KDE (h =", h, ", s =", s, ", k =", k, ")"),
xlab = "Value", ylab = "Density")
# Visualizing individual 'bumps' (scaled down for clarity)
for(xi in data) {
curve(dsinu(x, xi - h, 2*h, s, k) / n,
add = TRUE, col = rgb(0.5, 0.5, 0.5, 0.2), lwd = 1)
}
rug(data)
grid(alpha = 0.3)
})
}
shinyApp(ui = ui, server = server)
