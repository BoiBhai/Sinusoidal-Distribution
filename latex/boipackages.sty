\RequirePackage[textwidth=6.5in, textheight=9.0in]{geometry}
%\RequirePackage{pdflscape}
\RequirePackage{setspace}
\onehalfspacing % This is the standard command for 1.5 line spacing
\RequirePackage{graphicx, wrapfig, subcaption}
\RequirePackage{amsmath, amsfonts, amssymb, amsthm}
\RequirePackage{upgreek}
\RequirePackage{mathtools}
%\RequirePackage[skip=8pt]{parskip}
\RequirePackage{xcolor, hyperref}
\RequirePackage{xspace}
\RequirePackage{xargs}
\RequirePackage{enumitem}
\RequirePackage{booktabs}
\RequirePackage{tabularx}
\RequirePackage[bottom]{footmisc}

\RequirePackage[
    backend=biber,
    style=ext-authoryear
]{biblatex}
\RequirePackage{tocbibind}
\addbibresource{ref.bib}
\RequirePackage{appendix}

\RequirePackage{comment}

\hypersetup{
    colorlinks = true,
    menucolor=black,
    linkcolor=blue,          % color of internal links (change box color with linkbordercolor)
    citecolor=blue,        % color of links to bibliography
    urlcolor=red   
}

\theoremstyle{plain}
\newtheorem{thm}{Theorem}[section]
\newcommand{\thmautorefname}{Theorem}
\newtheorem{clm}{Claim}[section]
\newcommand{\clmautorefname}{Claim}
\theoremstyle{remark}
\newtheorem{rmk}{Remark}[section]
\newcommand{\rmkautorefname}{Remark}
\theoremstyle{definition}
\newtheorem{dfn}{Definition}


\NewDocumentEnvironment{proofof}{m}{
  \par\noindent
  \textbf{Proof of #1.}\enspace
}{
  \qed\par\medskip
}

