s.fit = function(s,k) -log(2)/log(sumdens.mode(s,k))
s.fit(3,2)
k.fit = function(s,k) uniroot(function(t) sinuarea(s.fit(s,k),t) - 1/sumdens.modaldens(s,k), c(1.1,10))$root
k.fit(3,2)
# Mode fitting strategy
